          "inline_data": null,
          "text": "I see that for pension appointments, we currently offer Online Meetings and Phone Calls. Branch Meetings are not available for pension consultations at this time.\n\nWould you like to book an Online Meeting or a Phone Call instead?",
          "thought": null,
          "thought_signature": null,
          "video_metadata": null
        }
