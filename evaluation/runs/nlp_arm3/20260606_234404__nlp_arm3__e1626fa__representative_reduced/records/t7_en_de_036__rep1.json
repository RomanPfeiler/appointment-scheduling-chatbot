          "executable_code": null,
          "file_data": null,
          "function_call": null,
          "function_response": null,
          "inline_data": null,
          "text": "Okay, an Online Meeting then. But it's important that this is a joint appointment for both my husband and me to discuss our shared pension. Can you ensure the booking reflects that it's for two people?",
          "thought": null,
          "thought_signature": null,
          "video_metadata": null
        }
